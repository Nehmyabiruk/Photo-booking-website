# MongoDB (primary database)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/amen-pictures

# Admin auth
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
ADMIN_EMAIL=admin@amenpictures.com
ADMIN_PASSWORD=admin123

# Email (SendGrid or SMTP via lib/email.js)
SENDGRID_API_KEY=
EMAIL_USER=amenpicture@outlook.com
EMAIL_FROM=info@amenpictures.com

# WhatsApp notifications
ADMIN_PHONE_NUMBER=12408551199

# Cloudinary (gallery uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: PostgreSQL/Prisma (legacy — bookings now use MongoDB)
# DATABASE_URL=postgresql://user:pass@localhost:5432/amen_pictures
